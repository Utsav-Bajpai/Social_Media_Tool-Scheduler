# Gemini API key — required
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# Supabase — optional. Without these, brand voice profiles and scheduled
# posts are stored in-memory (fine for local dev; for the scheduler
# specifically, set these before demoing — see note in scheduler_storage.py)
SUPABASE_URL=
SUPABASE_KEY=

# Redis — required for the scheduler. Use Upstash's "Redis" connection
# string (starts with rediss:// for TLS) in production; for local dev,
# a plain local Redis works too (redis://localhost:6379/0).
REDIS_URL=redis://localhost:6379/0

# 0.0 to 1.0 — chance a simulated publish "fails" so you can see the
# retry/backoff behavior in action. Set to 0 to always succeed.
SIMULATE_FAILURE_RATE=0.15
